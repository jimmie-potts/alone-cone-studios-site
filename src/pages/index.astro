---
import '../styles/global.css';

const emailAddress = 'hello@example.com';

const muralHighlights = [
  'Big bright murals for playful spaces.',
  'Custom walls for shops, homes, events, and community spots.',
  'Flora, fauna, odd little friends, and colorful worlds.',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Minnie's playful artist portfolio for murals and upcoming holiday window painting services."
    />
    <title>Minnie Art</title>
  </head>
  <body>
    <main>
      <section class="bg-butter px-5 py-16 sm:px-8 lg:px-12">
        <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div>
            <p class="mb-5 inline-block rounded-full border-2 border-ink bg-white px-4 py-2 text-sm font-bold uppercase tracking-wide">
              Murals now · Holiday windows soon
            </p>
            <h1 class="font-display text-5xl leading-tight sm:text-6xl lg:text-7xl">
              Minnie paints colorful little worlds.
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 sm:text-xl">
              Playful murals, cheerful storefront ideas, and art that makes a wall feel like an adventure.
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href="#contact"
                class="rounded-full border-2 border-ink bg-ink px-6 py-3 text-center font-bold text-white shadow-[4px_4px_0_#8f95ff] transition hover:-translate-y-0.5 focus:outline focus:outline-4 focus:outline-offset-4 focus:outline-periwinkle"
              >
                Email Minnie
              </a>
              <a
                href="#murals"
                class="rounded-full border-2 border-ink bg-white px-6 py-3 text-center font-bold shadow-[4px_4px_0_#8f95ff] transition hover:-translate-y-0.5 focus:outline focus:outline-4 focus:outline-offset-4 focus:outline-periwinkle"
              >
                See mural focus
              </a>
            </div>
          </div>
          <div class="rounded-[2rem] border-4 border-ink bg-white p-6 shadow-[10px_10px_0_#8f95ff]">
            <div class="grid aspect-square place-items-center rounded-[1.5rem] border-2 border-dashed border-ink bg-paper p-8 text-center">
              <div>
                <p class="font-display text-4xl">Artwork goes here</p>
                <p class="mt-4 text-sm font-bold uppercase tracking-wide">
                  Placeholder for Minnie's real mural photography
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="murals" class="px-5 py-16 sm:px-8 lg:px-12">
        <div class="mx-auto max-w-6xl">
          <h2 class="font-display text-4xl sm:text-5xl">Featured murals</h2>
          <div class="mt-8 grid gap-5 md:grid-cols-3">
            {muralHighlights.map((highlight) => (
              <article class="rounded-3xl border-2 border-ink bg-white p-6 shadow-[5px_5px_0_#f8e27c]">
                <p class="text-lg font-bold leading-7">{highlight}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-periwinkle px-5 py-16 text-ink sm:px-8 lg:px-12">
        <div class="mx-auto max-w-4xl rounded-[2rem] border-4 border-ink bg-white p-8 shadow-[8px_8px_0_#191919]">
          <p class="text-sm font-bold uppercase tracking-wide">Coming soon</p>
          <h2 class="mt-3 font-display text-4xl sm:text-5xl">Holiday window painting</h2>
          <p class="mt-5 text-lg leading-8">
            Holiday windows, happy walls, and colorful little worlds are on the way. Reach out if you are curious about a custom seasonal window for a storefront, event, or special space.
          </p>
        </div>
      </section>

      <section class="px-5 py-16 sm:px-8 lg:px-12">
        <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-2">
          <div>
            <h2 class="font-display text-4xl sm:text-5xl">About Minnie</h2>
            <p class="mt-5 text-lg leading-8">
              Minnie creates playful artwork for walls, windows, and bright little moments. More personal biography copy can be added when the real content is ready.
            </p>
          </div>
          <div>
            <h2 class="font-display text-4xl sm:text-5xl">Services</h2>
            <ul class="mt-5 space-y-3 text-lg font-bold">
              <li>Murals</li>
              <li>Holiday window painting inquiries</li>
              <li>Future art projects by request</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="contact" class="bg-ink px-5 py-16 text-white sm:px-8 lg:px-12">
        <div class="mx-auto max-w-4xl text-center">
          <h2 class="font-display text-4xl sm:text-5xl">Want a colorful wall or window?</h2>
          <p class="mx-auto mt-5 max-w-2xl text-lg leading-8">
            Email Minnie about murals or upcoming holiday window painting.
          </p>
          <a
            href={`mailto:${emailAddress}?subject=Minnie%20art%20inquiry`}
            class="mt-8 inline-block rounded-full border-2 border-white bg-butter px-6 py-3 font-bold text-ink shadow-[4px_4px_0_#8f95ff] transition hover:-translate-y-0.5 focus:outline focus:outline-4 focus:outline-offset-4 focus:outline-white"
          >
            {emailAddress}
          </a>
        </div>
      </section>
    </main>
  </body>
</html>
