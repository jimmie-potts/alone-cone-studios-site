---
import MuralGallery from '../components/MuralGallery.astro';
import { muralProjects } from '../data/murals';
import '../styles/global.css';

const formAction = 'https://formspree.io/f/REPLACE_WITH_FORM_ID';
const heroProject = muralProjects[0];
const featuredImage = heroProject.gallery[0] ?? heroProject.backgroundImage;
const thankYouImage = muralProjects[1]?.gallery[0] ?? featuredImage;

const trustedByPlaceholders = ['Local Shop', 'Community Space', 'Creative Studio', 'Small Business'];

const reviewPlaceholders = [
  {
    quote: 'Placeholder review: add a real client quote here before publishing.',
    name: 'Client Name',
  },
  {
    quote: "Placeholder review: use Minnie's real mural feedback when available.",
    name: 'Client Name',
  },
  {
    quote: 'Placeholder review: keep this section accurate and client-approved.',
    name: 'Client Name',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Minnie's mural portfolio, custom mural inquiries, and 2026 winter holiday window painting waitlist."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap"
      rel="stylesheet"
    />
    <title>Minnie Art | Custom Murals</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="#top" class="brand-mark">Minnie</a>
        <div class="nav-actions">
          <a href="#portfolio">Portfolio</a>
          <a href="#contact">Inquiry</a>
        </div>
      </nav>
    </header>

    <main id="main">
      <section id="top" class="hero-section" aria-labelledby="hero-heading">
        <img
          src={heroProject.backgroundImage.src}
          alt={heroProject.backgroundImage.alt}
          width="1200"
          height="900"
          class="hero-image"
          loading="eager"
        />
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <p class="eyebrow">Starting at $500.00</p>
          <h1 id="hero-heading">Murals.</h1>
          <p class="hero-subtitle">Hand painted. Custom. Murals.</p>
          <a href="#contact" class="hero-cta">Florida Based. Willing to Travel.</a>
        </div>
      </section>

      <section id="portfolio" class="feature-section" aria-labelledby="feature-heading">
        <div class="section-shell feature-grid">
          <div>
            <p class="section-label">Featured mural</p>
            <h2 id="feature-heading">One big wall, one colorful world.</h2>
            <p class="feature-copy">
              Placeholder description: replace this with a short, accurate note about a real Minnie mural once the final portfolio image is ready.
            </p>
          </div>
          <figure class="feature-photo">
            <img
              src={featuredImage.src}
              alt={featuredImage.alt}
              width="1200"
              height="900"
              loading="lazy"
            />
            <figcaption>Placeholder feature photo</figcaption>
          </figure>
        </div>
      </section>

      <section class="trusted-section" aria-labelledby="trusted-heading">
        <div class="section-shell">
          <p class="section-label">Trusted by</p>
          <h2 id="trusted-heading">Client logos coming soon.</h2>
          <div class="logo-row" aria-label="Placeholder client logos">
            {trustedByPlaceholders.map((name) => (
              <div class="logo-pill">
                <span>{name}</span>
                <small>Placeholder</small>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="reviews-section" aria-labelledby="reviews-heading">
        <div class="section-shell">
          <p class="section-label">Reviews</p>
          <h2 id="reviews-heading">Kind words go here.</h2>
          <div class="review-grid">
            {reviewPlaceholders.map((review) => (
              <figure class="review-card">
                <blockquote>{review.quote}</blockquote>
                <figcaption>{review.name} · Placeholder</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>

      <section class="windows-section" aria-labelledby="windows-heading">
        <div class="section-shell windows-card">
          <div>
            <p class="section-label">Coming soon</p>
            <h2 id="windows-heading">2026 winter holiday windows.</h2>
          </div>
          <p>
            Holiday window painting is opening soon. Join the 2026 winter waitlist for storefronts, businesses, homes, and seasonal spaces.
          </p>
          <a href="#contact" class="text-link">Join the waitlist</a>
        </div>
      </section>

      <section id="contact" class="contact-section" aria-labelledby="contact-heading">
        <div class="section-shell contact-grid">
          <div>
            <p class="section-label">Inquiry form</p>
            <h2 id="contact-heading">Tell Minnie about the wall.</h2>
            <p>
              This form is ready for Formspree. Replace the placeholder endpoint before launch.
            </p>
            <div id="thanks" class="thanks-card" hidden>
              <img
                src={thankYouImage.src}
                alt="Fun placeholder thank-you image for Minnie's inquiry form."
                width="1200"
                height="900"
                loading="lazy"
              />
              <p>Thank you! Minnie will read your note soon.</p>
            </div>
          </div>

          <form class="intake-form" action={formAction} method="POST">
            <input type="hidden" name="_subject" value="New Minnie mural inquiry" />
            <input type="hidden" name="_next" value="/?thanks=true#thanks" />

            <label>
              Name
              <input name="name" type="text" autocomplete="name" required />
            </label>

            <label>
              Email
              <input name="email" type="email" autocomplete="email" required />
            </label>

            <label class="full-span">
              Project description / questions
              <textarea name="project_description" rows="5" required></textarea>
            </label>

            <label>
              Square footage estimate
              <input name="square_footage" type="text" inputmode="decimal" />
            </label>

            <fieldset>
              <legend>Project setting</legend>
              <label><input type="radio" name="setting" value="Indoor" /> Indoor</label>
              <label><input type="radio" name="setting" value="Outdoor" /> Outdoor</label>
            </fieldset>

            <fieldset>
              <legend>Project type</legend>
              <label><input type="radio" name="project_type" value="Business" /> Business</label>
              <label><input type="radio" name="project_type" value="Residential" /> Residential</label>
              <label><input type="radio" name="project_type" value="Other" /> Other</label>
            </fieldset>

            <label>
              Budget
              <select name="budget">
                <option value="">Select a range</option>
                <option value="$500-$1,000">$500-$1,000</option>
                <option value="$1k-$3k">$1k-$3k</option>
                <option value="$3k-$5k">$3k-$5k</option>
                <option value="$5k+">$5k+</option>
              </select>
            </label>

            <label class="checkbox-row full-span">
              <input
                type="checkbox"
                name="holiday_window_waitlist"
                value="Yes, add me to the 2026 winter holiday window painting waitlist"
              />
              Add me to the 2026 winter holiday window painting waitlist.
            </label>

            <button class="submit-button full-span" type="submit">Submit inquiry</button>
          </form>
        </div>
      </section>

      <MuralGallery projects={muralProjects} />
    </main>

    <script>
      const params = new URLSearchParams(window.location.search);
      const thanks = document.querySelector('#thanks');
      if (params.get('thanks') === 'true' && thanks instanceof HTMLElement) {
        thanks.hidden = false;
      }

      const gallery = document.querySelector('[data-lock-gallery]');
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (gallery instanceof HTMLElement && !reducedMotion) {
        const panels = Array.from(gallery.querySelectorAll('[data-gallery-panel]'));
        const backgrounds = Array.from(gallery.querySelectorAll('[data-gallery-background]'));
        const counter = gallery.querySelector('[data-gallery-index]');
        let activeIndex = 0;
        let ticking = false;

        const setActive = (index: number) => {
          activeIndex = Math.max(0, Math.min(index, panels.length - 1));
          const activeValue = String(activeIndex);

          panels.forEach((panel) => {
            panel.classList.toggle('is-active', panel.getAttribute('data-gallery-panel') === activeValue);
          });

          backgrounds.forEach((background) => {
            background.classList.toggle(
              'is-active',
              background.getAttribute('data-gallery-background') === activeValue,
            );
          });

          if (counter) counter.textContent = String(activeIndex + 1);
        };

        const syncGalleryToScroll = () => {
          const rect = gallery.getBoundingClientRect();
          const maxTravel = gallery.offsetHeight - window.innerHeight;
          const progress = maxTravel > 0 ? Math.min(Math.max(-rect.top / maxTravel, 0), 1) : 0;
          const nextIndex = Math.round(progress * (panels.length - 1));
          setActive(nextIndex);
          ticking = false;
        };

        const requestSync = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(syncGalleryToScroll);
        };

        window.addEventListener('scroll', requestSync, { passive: true });
        window.addEventListener('resize', requestSync);
        window.addEventListener('keydown', (event) => {
          if (event.key === 'Home' || event.key === 'End') return;
          if (['ArrowDown', 'ArrowUp', 'PageDown', 'PageUp', ' '].includes(event.key)) {
            requestSync();
          }
        });

        syncGalleryToScroll();
      }
    </script>
  </body>
</html>
