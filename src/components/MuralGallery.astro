---
import type { MuralMedia, MuralVideo } from '../data/murals';

type Props = {
  images: MuralMedia[];
  videos: MuralVideo[];
};

const { images, videos } = Astro.props;
const midpoint = Math.ceil(images.length / 2);
const rows = [images.slice(0, midpoint), images.slice(midpoint)];
---

<section class="mural-gallery" aria-labelledby="mural-gallery-heading">
  <div class="gallery-heading section-shell">
    <p class="section-label">More murals</p>
    <h2 id="mural-gallery-heading">A whole bunch of painted walls.</h2>
  </div>

  <div class="marquee-gallery">
    {rows.map((row, rowIndex) => (
      <div class:list={['marquee-row', rowIndex === 1 && 'marquee-row-reverse']}>
        <div class="marquee-track">
          {[...row, ...row].map((item, index) => (
            <figure class="marquee-item" aria-hidden={index >= row.length ? 'true' : undefined}>
              <img src={item.src} alt={index >= row.length ? '' : item.alt} loading="lazy" />
            </figure>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="video-strip section-shell" aria-label="Mural videos">
    {videos.map((video) => (
      <figure class="video-card">
        <video controls preload="metadata" poster={video.poster} aria-label={video.title}>
          <source src={video.src} />
        </video>
        <figcaption>{video.title}</figcaption>
      </figure>
    ))}
  </div>
</section>
