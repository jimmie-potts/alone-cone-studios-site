---
import type { MuralProject } from '../data/murals';

type Props = {
  project: MuralProject;
  index: number;
};

const { project, index } = Astro.props;
const headingId = `mural-project-${index + 1}`;
const mediaItems = [
  ...project.gallery.map((item) => ({ type: 'image' as const, ...item })),
  ...project.videos.map((item) => ({ type: 'video' as const, ...item })),
];
---

<section class="mural-project" aria-labelledby={headingId}>
  <div class="project-backdrop" aria-hidden="true">
    <img
      src={project.backgroundImage.src}
      alt=""
      width="1200"
      height="900"
      loading={index === 0 ? 'eager' : 'lazy'}
    />
    <div class="project-backdrop-overlay"></div>
  </div>

  <div class="project-content">
    <div class="project-scenes" aria-label={`${project.title} related media`}>
      {mediaItems.map((item, mediaIndex) => (
        <figure class="project-scene">
          <div class="project-artwork">
            {item.type === 'image' ? (
              <img src={item.src} alt={item.alt} width="1200" height="900" loading="lazy" />
            ) : (
              <video controls preload="metadata" poster={item.poster}>
                <source src={item.src} />
              </video>
            )}
          </div>
          <figcaption class="project-title-overlay">
            <span id={mediaIndex === 0 ? headingId : undefined}>{project.title}</span>
            {item.isPlaceholder && <small>Placeholder</small>}
          </figcaption>
        </figure>
      ))}

      {mediaItems.length === 0 && (
        <figure class="project-scene">
          <div class="project-artwork">
            <img
              src={project.backgroundImage.src}
              alt={project.backgroundImage.alt}
              width="1200"
              height="900"
              loading={index === 0 ? 'eager' : 'lazy'}
            />
          </div>
          <figcaption class="project-title-overlay">
            <span id={headingId}>{project.title}</span>
            {project.backgroundImage.isPlaceholder && <small>Placeholder</small>}
          </figcaption>
        </figure>
      )}
    </div>
  </div>
</section>
